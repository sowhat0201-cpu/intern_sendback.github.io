<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>職場實習生類型測驗</title>
    <style>
        :root { --primary: #2c3e50; --accent: #3498db; --bg: #f4f7f6; }
        body { font-family: "Microsoft JhengHei", sans-serif; background: var(--bg); color: var(--primary); margin: 0; padding: 20px; }
        .container { max-width: 600px; margin: 0 auto; background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        h1 { text-align: center; color: var(--accent); }
        input[type="text"] { width: 100%; padding: 12px; margin: 20px 0; border: 2px solid #ddd; border-radius: 8px; box-sizing: border-box; text-align: center; font-size: 16px; }
        .btn { width: 100%; padding: 15px; background: var(--accent); color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 18px; font-weight: bold; }
        .opt-btn { width: 100%; padding: 12px; margin: 8px 0; border: 1px solid #ddd; background: #fff; border-radius: 8px; cursor: pointer; text-align: left; font-size: 16px; transition: 0.2s; }
        .opt-btn:hover { background: var(--accent); color: white; }
        .progress { background: #eee; height: 10px; border-radius: 5px; margin-bottom: 20px; overflow: hidden; }
        .progress-bar { background: var(--accent); height: 100%; width: 0%; transition: 0.3s; }
        #quiz-box, #result { display: none; }
        .advice-box { background: #ebf8ff; padding: 15px; border-radius: 8px; border-left: 5px solid var(--accent); margin-top: 15px; }
    </style>
</head>
<body>

<div class="container">
    <div id="login-page">
        <h1>🔍 職涯分身測驗</h1>
        <p style="text-align:center">請輸入你的姓名或學號開始測驗</p>
        <input type="text" id="user-name" placeholder="例如：王小明">
        <button class="btn" onclick="startQuiz()">開始測驗</button>
    </div>

    <div id="quiz-box">
        <div class="progress"><div class="progress-bar" id="pb"></div></div>
        <div id="question-container"></div>
    </div>

    <div id="result">
        <h1>📊 測驗結果</h1>
        <div id="result-content"></div>
        <p id="status" style="color: #27ae60; text-align: center; font-weight: bold;">✅ 結果同步中...</p>
        <button class="btn" style="background:#95a5a6" onclick="location.reload()">重新測驗</button>
    </div>
</div>

<script>
    // ⚠️ 這裡請貼上你的 Google Apps Script URL
    const scriptURL = 'https://script.google.com/macros/s/AKfycbxA9Jq_ix51DKLtRWlx0R5wCZz7hG7HHdANRMqQBJlsADFlRNH1LvcyEH8A4IcYdipHZg/exec
';

    const questions = [
        { q: "實習第一天報到，你會？", a: "觀察職稱與座位架構", b: "微笑打招呼記住名字", c: "思考動線哪裡可以更酷", d: "安靜等待指令" },
        { q: "拿到厚厚一疊須知，你會？", a: "直接看考核標準", b: "先看福利與聚餐", c: "隨意翻閱希望有圖解", d: "從第一頁認真劃重點" },
        { q: "主管正在教導流程，你會？", a: "邊聽邊想省時捷徑", b: "觀察主管表情表現受教", c: "想試試不用手冊能不能成", d: "拿出筆記本詳細記錄" },
        { q: "午高峰現場混亂，你會？", a: "精準完成交辦任務", b: "擔心大家在生我的氣", c: "想跳出來指揮大家", d: "更加小心翼翼怕犯錯" }
        // ... 其他題目可以自行補回
    ];

    let currentQ = 0;
    let scores = { a: 0, b: 0, c: 0, d: 0 };
    let uName = "";

    function startQuiz() {
        uName = document.getElementById('user-name').value;
        if (!uName) return alert("請輸入姓名！");
        document.getElementById('login-page').style.display = 'none';
        document.getElementById('quiz-box').style.display = 'block';
        showQuestion();
    }

    function showQuestion() {
        if (currentQ >= questions.length) return showResult();
        let q = questions[currentQ];
        let html = `<h3>${q.q}</h3>
            <button class="opt-btn" onclick="next('a')">A. ${q.a}</button>
            <button class="opt-btn" onclick="next('b')">B. ${q.b}</button>
            <button class="opt-btn" onclick="next('c')">C. ${q.c}</button>
            <button class="opt-btn" onclick="next('d')">D. ${q.d}</button>`;
        document.getElementById('question-container').innerHTML = html;
        document.getElementById('pb').style.width = (currentQ / questions.length * 100) + "%";
    }

    function next(ans) {
        scores[ans]++;
        currentQ++;
        showQuestion();
    }

    function showResult() {
        document.getElementById('quiz-box').style.display = 'none';
        document.getElementById('result').style.display = 'block';

        let max = Math.max(scores.a, scores.b, scores.c, scores.d);
        let type = "";
        let desc = "";

        if (scores.a == max) { type = "精準高效領航員"; desc = "你注重效率與邏輯，是團隊的智囊。"; }
        else if (scores.b == max) { type = "溫暖感性潤滑劑"; desc = "你擅長溝通與共情，是團隊的黏著劑。"; }
        else if (scores.c == max) { type = "靈感爆棚開拓者"; desc = "你充滿創意與好奇，是團隊的點子王。"; }
        else { type = "踏實穩定守護者"; desc = "你認真負責且沉穩，是團隊的基石。"; }

        document.getElementById('result-content').innerHTML = `<h2>${uName}，你是：${type}</h2><div class="advice-box">${desc}</div>`;

        // 背景上傳資料
        if (scriptURL.includes("https")) {
            fetch(scriptURL, {
                method: 'POST',
                mode: 'no-cors',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: uName, type: type, scores: scores })
            }).then(() => {
                document.getElementById('status').innerText = "✅ 結果已同步至雲端表格";
            }).catch(() => {
                document.getElementById('status').innerText = "❌ 同步失敗 (請確認 GAS URL)";
            });
        }
    }
</script>

</body>
</html>
